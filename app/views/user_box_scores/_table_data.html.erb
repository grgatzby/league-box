<%#
  League table rows: singles (player rows) or doubles/padel (team rows).
  Parameters:
    from: "index" (round ranking) or "index_league" (tournament ranking)

  Singles: user_box_scores — index: UserBoxScore records; index_league: [user, stats_hash]
  Doubles: @team_box_scores — TeamBoxScore records (uses @doubles_mode)
%>
<% is_index = from == "index" %>
<% show_box = is_index %>
<ol type="1" class="text-size">
  <% if @doubles_mode %>
    <% @team_box_scores.each do |tbs| %>
      <% box = tbs.box %>
      <% if is_index %>
        <% doubles_link_path = box_path(box, page_from: user_box_scores_path({ round_id: @round.id, club_id: @club.id }.merge(tournament_format_params)), round_id: @round.id, club_id: @club.id) %>
      <% else %>
        <% doubles_link_path = box_path(box, page_from: index_league_path({ league_start: @league_start, club_id: @club.id }.merge(tournament_format_params)), league_start: @league_start, club_id: @club.id) %>
      <% end %>
      <% team_row_highlight = tbs.team.users.include?(current_user) %>
      <% team_popover = doubles_team_row_popover_html(tbs.team, club_id: @club.id) %>
      <li class="league-table-row <%= 'color-tennis-red' if team_row_highlight %>">
        <%= tag.div style: "width: 100%;", data: {
          controller: "popover",
          bs_toggle: "popover",
          bs_html: true,
          bs_trigger: "hover focus",
          bs_placement: "bottom",
          bs_delay: { show: 500 },
          bs_content: team_popover.to_s
        } do %>
          <div class="one-liner hovered-player" style="width: 100%;">
          <div class="col-3"><%= tbs.team.display_name %></div>
          <div class="col-1 top-bottom-padding"><%= "# #{tbs.rank}" %></div>
          <div class="col-1 top-bottom-padding"><%= t("pts", count: tbs.points) %></div>
          <% if show_box %>
            <div class="col-1 top-bottom-padding"><%= box.box_number %></div>
          <% end %>
          <div class="col-1 top-bottom-padding"><%= t(".matches", count: tbs.matches_played, default: tbs.matches_played) %></div>
          <div class="col-1 top-bottom-padding"><%= t(".matches", count: tbs.matches_won, default: tbs.matches_won) %></div>
          <div class="col-1 top-bottom-padding"><%= t(".sets", count: tbs.sets_played, default: tbs.sets_played) %></div>
          <div class="col-1 top-bottom-padding"><%= t(".sets", count: tbs.sets_won, default: tbs.sets_won) %></div>
          <div class="col-1 top-bottom-padding"><%= t(".games", count: tbs.games_played, default: tbs.games_played) %></div>
          <div class="col-1 top-bottom-padding"><%= t(".games", count: tbs.games_won, default: tbs.games_won) %></div>
          <%= link_to "", doubles_link_path, class: "line-link" %>
          </div>
        <% end %>
      </li>
    <% end %>
  <% else %>
    <% user_box_scores.each do |user_bs| %>
      <% player = is_index ? user_bs.user : user_bs[0] %>
      <% next if player.role == "spare" %>
      <%
        rank = is_index ? user_bs.rank : user_bs[1][:rank]
        points = is_index ? user_bs.points : user_bs[1][:points]
        matches_played = is_index ? user_bs.matches_played : user_bs[1][:matches_played]
        matches_won = is_index ? user_bs.matches_won : user_bs[1][:matches_won]
        sets_played = is_index ? user_bs.sets_played : user_bs[1][:sets_played]
        sets_won = is_index ? user_bs.sets_won : user_bs[1][:sets_won]
        games_played = is_index ? user_bs.games_played : user_bs[1][:games_played]
        games_won = is_index ? user_bs.games_won : user_bs[1][:games_won]

        name = "#{render "shared/fullname", user: player}"
        if is_index
          message = "#{name}<br />📞 #{player.phone_number}<br />✉️ #{player.email}"
        else
          message = player_league_popover_html(player, club_id: @club.id)
        end
        if is_index
          link_path = box_path(user_bs.box, page_from: user_box_scores_path({ round_id: @round.id, club_id: @club.id }.merge(tournament_format_params)), round_id: @round.id, club_id: @club.id)
        else
          box = player.user_box_scores.map(&:box).select { |box| box.round == user_bs[1][:last_round] }[0]
          link_path = box_path(box, page_from: index_league_path({ league_start: @league_start, club_id: @club.id }.merge(tournament_format_params)), league_start: @league_start, club_id: @club.id)
        end
      %>
      <li class="league-table-row <%= 'color-tennis-red' if player == current_user %>">
        <%= tag.div style: "width: 100%;", data: {
          controller: "popover",
          bs_toggle: "popover",
          bs_html: true,
          bs_trigger: "hover focus",
          bs_placement: "bottom",
          bs_delay: { show: 500 },
          bs_content: message.to_s
        } do %>
          <div class="one-liner hovered-player" style="width: 100%;">
            <div class="col-3">
              <%= image_tag(player_profile_picture_or_favicon(player, 30), alt: 'Profile picture', style: "width: 30px; height: 30px; border-radius: 50%; object-fit: cover; flex-shrink: 0;") %>
              <%= render "shared/fullname", user: player %>
            </div>

            <div class="col-1 top-bottom-padding"><%= "# #{rank}" %></div>
            <div class="col-1 top-bottom-padding"><%= t("pts", count: points) %></div>

            <% if show_box %>
              <div class="col-1 top-bottom-padding"><%= "#{user_bs.box.box_number}" %></div>
            <% end %>

            <div class="col-1 top-bottom-padding"><%= t(".matches", count: matches_played) %></div>
            <div class="col-1 top-bottom-padding"><%= t(".matches", count: matches_won) %></div>
            <div class="col-1 top-bottom-padding"><%= t(".sets", count: sets_played) %></div>
            <div class="col-1 top-bottom-padding"><%= t(".sets", count: sets_won) %></div>
            <div class="col-1 top-bottom-padding"><%= t(".games", count: games_played) %></div>
            <div class="col-1 top-bottom-padding"><%= t(".games", count: games_won) %></div>

            <%= link_to '', link_path, class: 'line-link'%>
          </div>
        <% end %>
      </li>
    <% end %>
  <% end %>
</ol>
