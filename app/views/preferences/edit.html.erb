
  <%# My details form for existing user %>
<%= render "shared/image_front" %>
<%# Reusable JavaScript function for DOM ready checks %>
<script>
  // Helper function to run code when DOM is ready
  function runWhenReady(callback) {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', callback);
    } else {
      callback();
    }
  }
</script>
<div class="<%= class_names("container": !@is_mobile) %>">
  <div class="one-liner">
    <h3><%= t '.title' %></h3>
  </div>
  <%# Removed Active Storage photo code - now using CarrierWave on User model for profile pictures %>

  <%= form_with model: @preference, method: @preference.id ? :patch : :post, multipart: true do |preference_f| %>

    <div class="frame-color-shape frame-padding frame-margin-rl text-size box-scroller" >
      <div style="display: flex; align-items: center; justify-content: center; gap: 10px;">
        <% if current_user.profile_picture.present? %>
          <%= image_tag(profile_picture_circular_url(current_user, 40), alt: 'Profile picture', id: "top_profile_picture", style: "width: 40px; height: 40px; border-radius: 50%; object-fit: cover;") %>
        <% else %>
          <img id="top_profile_picture" alt="Profile picture" style="display: none; width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
        <% end %>
        <b><%= render "shared/fullname", user: current_user %></b>
      </div>
      <br><br>

      <%# Display-only information rows %>
      <%= render "preferences/display_row",
          emoji: "🎾",
          label: "Club",
          value: (current_user == @admin ? current_user.club.name : selected_club.name).titleize %>
      <%= render "preferences/display_row",
          emoji: "🧩",
          label: t(".role"),
          value: current_user == @admin ? current_user.role : selected_club.role %>

      <%# Editable form fields %>
      <%= render "preferences/form_field",
          form: preference_f,
          field_name: :nickname,
          emoji: "😎",
          label_text: t(".nickname"),
          placeholder: current_user.nickname,
          field_value: current_user.nickname,
          width: "15em" %>
      <%= render "preferences/form_field",
          form: preference_f,
          field_name: :first_name,
          emoji: "👤",
          label_text: t(".first_name"),
          placeholder: current_user.first_name,
          field_value: current_user.first_name,
          width: "15em" %>
      <%= render "preferences/form_field",
          form: preference_f,
          field_name: :last_name,
          emoji: "👤",
          label_text: t(".last_name"),
          placeholder: current_user.last_name,
          field_value: current_user.last_name,
          width: "15em" %>
      <%= render "preferences/form_field",
          form: preference_f,
          field_name: :e_mail,
          emoji: "📩",
          label_text: t(".e_mail"),
          placeholder: current_user.email,
          field_value: current_user.email,
          width: "20em" %>
      <%= render "preferences/form_field",
          form: preference_f,
          field_name: :phone_number,
          emoji: "📞",
          label_text: t(".phone_number"),
          placeholder: current_user.phone_number,
          field_value: current_user.phone_number,
          width: "10em" %>
     <hr>

      <div class="row">
        <div class="col-4"><%= label_tag "user[profile_picture]", t(".profile_picture") %></div>
        <div class="col-8">
          <div style="display: flex; align-items: center; gap: 15px;">
            <div class="custom-file-input-wrapper">
              <%= file_field_tag "user[profile_picture]", accept: "image/jpeg,image/jpg,image/png,image/gif,image/webp", class: "form-control custom-file-input", id: "profile_picture_input" %>
              <label for="profile_picture_input" class="custom-file-label btn btn-shape btn-beige">
                <%= t(".choose_file") %>
              </label>
            </div>
            <div id="profile_picture_preview">
              <% if current_user.profile_picture.present? %>
                <%= image_tag(current_user.profile_picture.url.to_s, alt: 'Profile picture', class: "rounded", style: "max-width: 100px; max-height: 100px;", id: "preview_image") %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
      <script>
        (function() {
          function initProfilePicturePreview() {
            const fileInput = document.getElementById('profile_picture_input');
            const previewContainer = document.getElementById('profile_picture_preview');
            const topProfilePicture = document.getElementById('top_profile_picture');

            if (!fileInput || !previewContainer) {
              console.warn('Profile picture preview elements not found');
              return;
            }

            fileInput.addEventListener('change', function(e) {
              if (e.target.files && e.target.files.length > 0) {
                const file = e.target.files[0];

                // Validate file type
                if (!file.type.match('image.*')) {
                  console.warn('Selected file is not an image');
                  return;
                }

                const reader = new FileReader();

                reader.onload = function(event) {
                  const imageUrl = event.target.result;

                  // Update top circular profile picture
                  if (topProfilePicture) {
                    topProfilePicture.src = imageUrl;
                    topProfilePicture.style.display = 'block';
                  }

                  // Update or create preview image
                  let previewImg = previewContainer.querySelector('img');
                  if (previewImg) {
                    previewImg.src = imageUrl;
                  } else {
                    previewImg = document.createElement('img');
                    previewImg.src = imageUrl;
                    previewImg.alt = 'Profile picture preview';
                    previewImg.className = 'rounded';
                    previewImg.style.cssText = 'max-width: 100px; max-height: 100px;';
                    previewContainer.insertBefore(previewImg, previewContainer.firstChild);

                    // Add line breaks for spacing if they don't exist
                    if (!previewContainer.querySelector('br')) {
                      const br1 = document.createElement('br');
                      const br2 = document.createElement('br');
                      previewContainer.appendChild(br1);
                      previewContainer.appendChild(br2);
                    }
                  }
                };

                reader.onerror = function() {
                  console.error('Error reading file');
                };

                reader.readAsDataURL(file);
              }
            });
          }

          // Run when DOM is ready
          runWhenReady(initProfilePicturePreview);
        })();
      </script>


      <div class="row">
        <div class="col-4"><%= preference_f.label :password, "🔐 #{t(".password")}:" %></div>
        <div class="col-8">
          <small><i><%= preference_f.label :password, t(".modify_password") %></i></small>
          &nbsp;&nbsp;<%= check_box_tag(:password,"1", params[:password].eql?("1")) %>
        </div>
      </div>

      <hr>
      <b><%= t(".preferences") %></b><br>
        <%# checkbox to remove color gradient formatting if page does not display well on screen %>
        <%# check_box_tag(:clear_format,"1", params[:clear_format].eql?("1"), onchange: "this.form.submit();") %>
      <div class="row">
        <div class="col-4"><%= t(".expanded_view") %></div>
        <div class="col-8">
          <small><i><%= preference_f.label :clear_format, t(".clear_format") %></i></small>
          &nbsp;&nbsp;<%= check_box_tag(:clear_format,"1", @preference.clear_format.eql?(true)) %>
        </div>
      </div>

      <% if (["player", "player referee"].include?(current_user.role)) %>
        <hr>
        <b><%= t(".history") %></b><br>
        <div class="row">
          <div class="col-4">
            <%= t(".previous_rounds") %>
          </div>
          <div class="col-8">
            <i><%= "League_Round - Box, #rank" %></i><br>
            <% name = "#{render "shared/fullname", user: current_user}"
              boxes = current_user.user_box_scores.map{ |ubs| "#{round_label(ubs.box.round)} - Box#{format('%02d', ubs.box.box_number)}, ##{ubs.rank},<br />" }.sort.join[0...-7] %>
            <%= sanitize "#{boxes}" %>
          </div>
        </div>
      <% end %>

      <%# My Club Section: Allow admin/referee to edit club website %>
      <% if current_user && (current_user.role&.include?("referee") || current_user == @admin) %>
        <% if current_user == @admin %>
          <% available_clubs = Club.all.reject { |c| c == @sample_club } %>
          <% selected_club_id = if params[:club_id].present?
                                   params[:club_id].to_i
                                 elsif available_clubs.any?
                                   available_clubs.first.id
                                 else
                                   current_user.club.id
                                 end %>
          <% selected_club = Club.find(selected_club_id) %>

        <hr>
        <div class="row">
          <div class="col-4"><b><%= t(".club_details") %></b></div>
          <small class="col-8"><i><%= t(".website_note_html", inset: "<a class='btn btn-inlayed bold-font color-blue' href='#{my_club_path}'>#{t ".website_note_club"}</a>".html_safe) %></i></small>
        </div>
        <% if current_user == @admin %>
          <%# Admin club selection dropdown (not a separate form, just updates the hidden field) %>
          <div class="row mb-3">
            <div class="col-4"><%= label_tag :club_id, t(".select_club"), class: "form-label" %></div>
            <div class="col-8">
              <%= select_tag :club_id,
                  options_for_select(available_clubs.map { |club| [club.name, club.id] }, selected_club_id),
                  { class: "form-control", id: "club_select_dropdown", style: "width: 20em; max-width: 100%" } %>
            </div>
          </div>
          <%# Store club data for JavaScript (embedded in script tag) %>
          <script type="application/json" id="clubs-data">
            <%= available_clubs.map { |club|
              rounds = club.rounds.order(start_date: :desc)
              {
                id: club.id,
                website: club.website || "",
                tiebreak_points: club.tiebreak_points,
                rounds: rounds.map { |round|
                  {
                    id: round.id,
                    label: round_label(round),
                    start_date: round.start_date.strftime("%d/%m/%Y"),
                    end_date: round.end_date.strftime("%d/%m/%Y"),
                    tiebreak_points: round.tiebreak_points
                  }
                }
              }
            }.to_json.html_safe %>
          </script>
        <% else %>
          <%# Referee can only edit their own club %>
          <% selected_club = current_user.club %>
        <% end %>

        <%# Website update field %>
        <div class="row">
          <div class="col-4"><%= preference_f.label :website, "🌐 #{t(".website")}:", for: "website_input" %></div>
          <div class="col-8">
            <%= preference_f.text_field :website,
                placeholder: t(".website_placeholder"),
                value: selected_club.website,
                #style: "width: 100%; max-width: 30em",
                style: "width: 20em; max-width: 100%",
                class: "form-control",
                id: "website_input" %>
            <small class="form-text text-muted"><i><%= t(".website_help") %></i></small>
          </div>
        </div>

        <%# Club Tiebreak Points update field (admin only) %>
        <% if current_user == @admin %>
          <div class="row">
            <div class="col-4"><%= label_tag :club_tiebreak_points, "🎾 #{t(".club_tiebreak_points")}:", class: "form-label", for: "club_tiebreak_points_input" %></div>
            <div class="col-8">
              <%= number_field_tag :club_tiebreak_points,
                  selected_club.tiebreak_points,
                  min: 7,
                  class: "form-control",
                  style: "width: 10em; max-width: 100%",
                  id: "club_tiebreak_points_input" %>
              <small class="form-text text-muted"><i><%= t(".club_tiebreak_points_help") %></i></small>
            </div>
          </div>
        <% end %>

        <%# JavaScript to update website and club tie-break fields when club dropdown changes (admin only) %>
        <% if current_user == @admin %>
          <script>
            (function() {
              function setupClubDropdown() {
                const clubSelect = document.getElementById('club_select_dropdown');

                if (!clubSelect) {
                  console.warn('Club dropdown not found');
                  return;
                }

                // Remove any existing change handlers by using onclick attribute
                clubSelect.onchange = null;

                // Add new change handler
                clubSelect.addEventListener('change', function(e) {
                  const selectedClubId = parseInt(this.value);

                  if (isNaN(selectedClubId)) {
                    console.warn('Invalid club ID:', this.value);
                    return;
                  }

                  // Always reload page to update Round Tie-break section for the selected club
                  const url = new URL(window.location.href);
                  url.searchParams.set('club_id', selectedClubId);
                  url.searchParams.set('scroll_to_bottom', 'true');
                  // Add timestamp to ensure URL is always different and forces reload
                  url.searchParams.set('_t', Date.now().toString());

                  // Force navigation
                  window.location.href = url.toString();
                }, { once: false });
              }

              // Initialize when DOM is ready
              runWhenReady(setupClubDropdown);
            })();
          </script>
        <% end %>
        <%# Hidden field for club_id (top-level parameter, not nested under preference) %>
        <%= hidden_field_tag :club_id, selected_club.id, id: "website_club_id" %>
        <% else %>
          <%# Referee can only edit their own club %>
          <% selected_club = current_user.club %>
          <hr>
          <div class="row">
            <div class="col-4"><b><%= t(".club_details") %></b></div>
            <small class="col-8"><i><%= t(".website_note_html", inset: "<a class='btn btn-inlayed bold-font color-blue' href='#{my_club_path}'>#{t ".website_note_club"}</a>".html_safe) %></i></small>
          </div>
          <%# Website update field %>
          <div class="row">
            <div class="col-4"><%= preference_f.label :website, "🌐 #{t(".website")}:", for: "website_input" %></div>
            <div class="col-8">
              <%= preference_f.text_field :website,
                  placeholder: t(".website_placeholder"),
                  value: selected_club.website,
                  style: "width: 20em; max-width: 100%",
                  class: "form-control",
                  id: "website_input" %>
              <small class="form-text text-muted"><i><%= t(".website_help") %></i></small>
            </div>
          </div>
          <%= hidden_field_tag :club_id, selected_club.id, id: "website_club_id" %>
        <% end %>
      <% end %>

      <%# Round Tie-break Configuration Section: Allow referee/admin to edit tiebreak_points for rounds %>
      <% if current_user && (current_user.role&.include?("referee") || current_user == @admin) %>
        <%# Get rounds for the selected club (admin) or current user's club (referee) %>
        <% if current_user == @admin %>
          <% available_clubs = Club.where.not(id: @sample_club&.id) %>
          <% rounds_club_id = if params[:club_id].present?
                                params[:club_id].to_i
                              elsif available_clubs.any?
                                available_clubs.first.id
                              else
                                current_user.club.id
                              end %>
          <% rounds_club = Club.find(rounds_club_id) %>
        <% else %>
          <% rounds_club = current_user.club %>
        <% end %>

        <hr>
        <div class="row">
          <div class="col-4"><b><%= t(".round_tiebreak_configuration") %></b></div>
          <small class="col-8"><i><%= t(".round_tiebreak_help") %></i></small>
        </div>
        <% rounds = rounds_club.rounds.order(start_date: :desc) %>
        <div id="rounds_container">
          <% if rounds.any? %>
            <% selected_round = rounds.first %>
            <%# Store rounds data for JavaScript %>
            <script type="application/json" id="rounds-data">
              <%= rounds.map { |round|
                {
                  id: round.id,
                  label: round_label(round),
                  start_date: round.start_date.strftime("%d/%m/%Y"),
                  end_date: round.end_date.strftime("%d/%m/%Y"),
                  tiebreak_points: round.tiebreak_points
                }
              }.to_json.html_safe %>
            </script>

            <div class="row mb-3">
              <div class="col-4">
                <%= label_tag :selected_round_id, t(".round"), class: "form-label" %>

                <small class="text-muted" id="round_dates_text">
                  (<%= selected_round.start_date.strftime("%d/%m/%Y") %> - <%= selected_round.end_date.strftime("%d/%m/%Y") %>)
                </small>
              </div>
              <div class="col-8">
                <%= select_tag :selected_round_id,
                    options_for_select(
                      rounds.map { |round|
                        ["#{round_label(round)} (#{round.start_date.strftime("%d/%m/%Y")} - #{round.end_date.strftime("%d/%m/%Y")})", round.id]
                      },
                      selected_round.id
                    ),
                    class: "form-control",
                    id: "round_select_dropdown",
                    style: "width: 20em; max-width: 100%" %>
              </div>
            </div>

            <div class="row mb-3">
              <div class="col-4">
                <%= label_tag :selected_round_tiebreak_points, "#{t(".round")} #{round_label(selected_round)}:", class: "form-label", id: "round_tiebreak_label" %>
              </div>
              <div class="col-8">
                <%= number_field_tag :selected_round_tiebreak_points,
                    selected_round.tiebreak_points,
                    min: 7,
                    class: "form-control",
                    style: "width: 10em; max-width: 100%",
                    placeholder: rounds_club.tiebreak_points.to_s,
                    id: "selected_round_tiebreak_points_input" %>
                <small class="form-text text-muted">
                  <i id="round_inherits_text">
                    <% if selected_round.tiebreak_points.nil? %>
                      <%= t(".inherits_from_club", points: rounds_club.tiebreak_points) %>
                    <% else %>
                      <%= t(".overrides_club", points: selected_round.tiebreak_points, club_points: rounds_club.tiebreak_points) %>
                    <% end %>
                  </i>
                </small>
              </div>
            </div>

            <%# JavaScript to update tiebreak_points field when round dropdown changes %>
            <script>
              (function() {
                const roundSelect = document.getElementById('round_select_dropdown');
                const roundsDataElement = document.getElementById('rounds-data');
                const tiebreakInput = document.getElementById('selected_round_tiebreak_points_input');
                const roundDatesText = document.getElementById('round_dates_text');
                const roundTiebreakLabel = document.getElementById('round_tiebreak_label');
                const roundInheritsText = document.getElementById('round_inherits_text');

                if (!roundSelect || !roundsDataElement || !tiebreakInput) {
                  return;
                }

                const roundsData = JSON.parse(roundsDataElement.textContent || '[]');
                const clubTiebreakPoints = <%= rounds_club.tiebreak_points %>;

                // Translation strings
                const translations = {
                  round: <%= t(".round").to_json.html_safe %>,
                  inheritsTemplate: <%= t(".inherits_from_club", points: "__POINTS__").to_json.html_safe %>,
                  overridesTemplate: <%= t(".overrides_club", points: "__POINTS__", club_points: "__CLUB_POINTS__").to_json.html_safe %>
                };

                function updateRoundFields(round) {
                  if (!round) return;

                  // Update tiebreak points input
                  const tiebreakValue = round.tiebreak_points !== null && round.tiebreak_points !== undefined ? round.tiebreak_points : '';
                  tiebreakInput.value = tiebreakValue;
                  tiebreakInput.placeholder = clubTiebreakPoints;

                  // Update dates text
                  if (roundDatesText) {
                    roundDatesText.textContent = round.start_date + ' - ' + round.end_date;
                  }

                  // Update label
                  if (roundTiebreakLabel) {
                    roundTiebreakLabel.textContent = translations.round + ' ' + round.label + ':';
                  }

                  // Update help text
                  if (roundInheritsText) {
                    if (round.tiebreak_points === null || round.tiebreak_points === undefined) {
                      roundInheritsText.textContent = translations.inheritsTemplate.replace('__POINTS__', clubTiebreakPoints);
                    } else {
                      roundInheritsText.textContent = translations.overridesTemplate
                        .replace('__POINTS__', round.tiebreak_points)
                        .replace('__CLUB_POINTS__', clubTiebreakPoints);
                    }
                  }
                }

                roundSelect.addEventListener('change', function() {
                  const selectedRoundId = parseInt(this.value);
                  const selectedRound = roundsData.find(round => round.id === selectedRoundId);
                  updateRoundFields(selectedRound);
                });
              })();
            </script>
          <% else %>
            <div class="row">
              <div class="col-12"><i><%= t(".no_rounds") %></i></div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    <br>
    <div class = "buttons-wrap">
      <%= preference_f.submit t(".submit_button"), class: "btn btn-shape btn-aqua" %>
    </div>
  <% end %>

</div>
<%# Scroll to bottom when admin changes club %>
<% if current_user == @admin && params[:scroll_to_bottom] == 'true' %>
  <script>
    (function() {
      function scrollToBottom() {
        // Find the scrollable div container (box-scroller class)
        const scrollableDiv = document.querySelector('.box-scroller');

        // Scroll the div container to the bottom if it exists
        if (scrollableDiv) {
          scrollableDiv.scrollTop = scrollableDiv.scrollHeight;
        }

        // Also scroll the entire page to the bottom
        window.scrollTo({
          top: document.body.scrollHeight,
          behavior: 'smooth'
        });

        // Remove the scroll and timestamp parameters from URL without reloading
        const url = new URL(window.location);
        url.searchParams.delete('scroll_to_bottom');
        url.searchParams.delete('_t');
        window.history.replaceState({}, '', url.toString());
      }

      // Wait for page to fully load, then scroll to bottom
      runWhenReady(function() {
        setTimeout(scrollToBottom, 100);
      });
    })();
  </script>
<% end %>
