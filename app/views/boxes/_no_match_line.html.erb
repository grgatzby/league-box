<%#
  No Match Line Partial
  Displays an unplayed match in list view format.
  Shows opponent name and either "Enter score" link (if authorized) or "Not played" text.
  Authorization: player in their own box, admin, or referee for current round.
%>
<li>
  <div class="row hovered-player color-tennis-blue">
    <%# Opponent Name Column (col-4) %>
    <div class="col-4"><%= doubles_mode ? opponent.display_name : render("shared/fullname", user: opponent) %></div>

    <%# Check if user is authorized to enter a score %>
    <% referee_or_admin = current_user.role == "admin" || current_user.role.to_s.include?("referee") %>
    <% may_enter_score = if doubles_mode
                           player.users.include?(current_user) || referee_or_admin
                         else
                           current_user == player || referee_or_admin
                         end %>

    <%# Match Status Column (col-8): Enter score link or "Not played" text %>
    <div class="col-8">
      <% if may_enter_score %>
        <%# Authorized: Show clickable "Enter match score" link with popover %>
        <% lhs = doubles_mode ? player.display_name : render("shared/fullname", user: player) %>
        <% rhs = doubles_mode ? opponent.display_name : render("shared/fullname", user: opponent) %>
        <% message = "#{lhs}<i>vs</i> #{rhs}<br>#{t(".pop02_a")}" %>
        <div data-controller="popover" data-bs-html="true" data-bs-toggle="popover"
            data-bs-trigger="hover" data-bs-placement="bottom" data-html="true" data-bs-delay= '{ "show": 500 }'
            data-bs-content="<%= message %>">
          <%# Click to navigate to new match score form %>
          <% if doubles_mode %>
            <%= link_to t('.enter_score'),
                        new_match_path(player: current_user.id, opponent: current_user.id, round_id: @box.round_id,
                                       team_a_id: player.id, team_b_id: opponent.id, page_from: page_from),
                        style: "color: #198754; text-decoration: none; font-style: italic;" %>
          <% else %>
            <%= link_to t('.enter_score'),
                        new_match_path(player: player.id, opponent: opponent.id, round_id: @box.round_id, page_from: page_from),
                        style: "color: #198754; text-decoration: none; font-style: italic;" %>
          <% end %>
        </div>
      <% else %>
        <%# Not Authorized: Show "Not played" text (non-clickable) %>
        <%= t('.not_played') %>
      <% end %>
  </div>
</li>
